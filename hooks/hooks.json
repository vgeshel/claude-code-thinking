{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v bun >/dev/null 2>&1 || echo '[claude-thinking] Warning: bun is not installed. The sycophancy and thinking hooks require it. Install from https://bun.sh' >&2",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | bun run ${CLAUDE_PLUGIN_ROOT}/hooks/check-sycophancy.ts",
            "timeout": 5,
            "statusMessage": "Checking for sycophancy..."
          },
          {
            "type": "command",
            "command": "cat | bun run ${CLAUDE_PLUGIN_ROOT}/hooks/check-thinking.ts",
            "timeout": 5,
            "statusMessage": "Checking for thinking checklist..."
          }
        ]
      }
    ]
  }
}
